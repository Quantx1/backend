# Runtime B2 model cache — restored at startup, never baked into the image.
artifacts/cache/

# Local virtualenv — multi-GB, and would otherwise be sent as build context.
.venv/
venv/

# VCS
.git/
.githooks/
.github/

# Python bytecode / tooling caches
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
.coverage
coverage.xml
htmlcov/

# Tests and docs aren't needed in the API image
tests/
docs/

# Local secrets — inject via the platform's env vars instead
.env
.env.*
!.env.example
